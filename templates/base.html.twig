<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Shop Mood{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {# Fonts lel man6ar el luxury #}
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

        {% block stylesheets %}{% endblock %}
    </head>
    <body style="background-color: #fcfcfc; font-family: 'Inter', sans-serif;">
        
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3" href="{{ path('app_home') }}" style="font-family: 'Playfair Display', serif;">
                    Shop Mood 🛍️
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <div class="navbar-nav ms-auto align-items-center">
                        
                        {# --- PANIER (Design ndhif) --- #}
                        <a class="nav-link me-3 position-relative" href="{{ path('cart_index') }}">
                            <i class="fas fa-shopping-cart fs-5"></i>
                            <span class="badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle" style="font-size: 0.6rem;">
                                {{ app.session.get('panier') ? app.session.get('panier')|length : 0 }}
                            </span>
                        </a>

                        {# --- ADMIN ACCESS --- #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="nav-link text-warning me-2 small fw-bold" href="{{ path('app_produit_new') }}">
                                <i class="fas fa-plus-circle me-1"></i> Produit
                            </a>
                        {% endif %}

                        <div class="d-flex align-items-center ms-lg-3 gap-2">
                            {% if app.user %}
                                <span class="nav-link text-light me-2 small">Hello, {{ app.user.userIdentifier|slice(0, 8) }}.. 👋</span>
                                <a class="nav-link btn btn-outline-light btn-sm px-3 rounded-0" href="{{ path('app_logout') }}">Déconnexion</a>
                            {% else %}
                                <a class="nav-link text-white me-3 mt-1" href="{{ path('app_login') }}">Connexion</a>
                                {# Houni el "S'inscrire" wallat d-tharek kima t7eb #}
                                <a href="{{ path('app_register') }}" class="btn-animated-light text-decoration-none">
                                    S'inscrire
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        {# --- FLASH MESSAGES --- #}
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show shadow-sm border-0 rounded-0" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <div class="container mt-4">
            {% block body %}{% endblock %}
        </div>

        {# Bootstrap JS #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>