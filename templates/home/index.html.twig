{% extends 'base.html.twig' %}

{% block title %}Accueil - MoodScent ✨{% endblock %}

{% block body %}
<div class="container mt-5">
    {# --- SECTION HEADER --- #}
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Trouvez votre Mood ✨</h1>
        <p class="lead text-muted">Choisissez une ambiance pour découvrir nos parfums</p>
    </div>

    {# --- SECTION FILTRES (MOODS) --- #}
    <div class="text-center mb-5">
        <a href="{{ path('app_home') }}" class="btn btn-secondary shadow-sm mx-1 px-4">Tout</a>
        <a href="{{ path('app_home', {'mood': 'Happy'}) }}" class="btn btn-warning shadow-sm mx-1 px-4 text-white">😊 Happy</a>
        <a href="{{ path('app_home', {'mood': 'Relax'}) }}" class="btn btn-success shadow-sm mx-1 px-4">🌿 Relax</a>
        <a href="{{ path('app_home', {'mood': 'Energetic'}) }}" class="btn btn-info shadow-sm mx-1 px-4 text-white">🔥 Energetic</a>
        <a href="{{ path('app_home', {'mood': 'Romantic'}) }}" class="btn btn-danger shadow-sm mx-1 px-4">💖 Romantic</a>
    </div>

    <hr class="mb-5">

    {# --- GRILLE DES PRODUITS --- #}
    <div class="row">
        {% for produit in produits %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden card-hover">
                    
                    {# Badge Mood #}
                    <span class="badge bg-light text-dark border position-absolute top-0 end-0 m-3 shadow-sm" style="z-index: 10;">
                        {{ produit.mood }}
                    </span>

                    {# 1. Zone Image #}
                    <div style=" overflow: hidden; background-color: #f8f9fa;">
                        {% if produit.image %}
                            {# templates/home/index.html.twig (walla blasa elli fiha el cards) #}

<img src="{{ asset('uploads/produits/' ~ produit.image) }}" 
     class="card-img-top" 
     alt="{{ produit.nom }}">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <span>No Image 📸</span>
                            </div>
                        {% endif %}
                    </div>

                    {# 2. Zone Détails #}
                    <div class="card-body text-center d-flex flex-column">
                        <h5 class="card-title fw-bold text-uppercase" style="letter-spacing: 1px;">
                            {{ produit.nom }}
                        </h5>
                        
                        <p class="card-text text-muted flex-grow-1 small mt-2 px-2">
                            {{ produit.description|length > 80 ? produit.description|slice(0, 80) ~ '...' : produit.description }}
                        </p>
                        
                        <div class="mt-3 mb-3">
                            <h4 class="text-primary fw-bold mb-0">{{ produit.prix }} <small>DT</small></h4>
                        </div>
                        
                        {# --- BOUTON AJOUTER AU PANIER --- #}
                        {# Hedha el lien elli ihez lel CartController #}
                        <a href="{{ path('cart_add', {'id': produit.id}) }}" class="btn btn-dark w-100 py-2 fw-bold shadow-sm">
                            Ajouter au panier 🛒
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            {# --- CAS OÙ IL N'Y A PAS DE PRODUITS --- #}
            <div class="col-12 text-center py-5">
                <div class="alert alert-light border shadow-sm p-5">
                    <h2 class="display-1">🧐</h2>
                    <h4 class="mt-3">Aucun parfum trouvé pour ce mood.</h4>
                    <p class="text-muted">Essayez de changer de catégorie ou revenez plus tard.</p>
                    <a href="{{ path('app_home') }}" class="btn btn-primary mt-3">Voir tous les parfums</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

{# CSS pour améliorer le design #}
<style>
    .card-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    .btn { transition: 0.2s; }
    .btn:active { transform: scale(0.95); }
</style>
{% endblock %}