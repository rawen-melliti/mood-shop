{% extends 'base.html.twig' %}

{% block title %}Connexion - MoodScent{% endblock %}

{% block body %}
<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    {# Na7ina l-formulaire l-m-farchakh w 7attineh f'west Card anique #}
    <div class="card border-0 shadow-sm p-4 p-md-5" style="max-width: 450px; width: 100%; background-color: #ffffff;">
        
        <form method="post">
            {% if error %}
                <div class="alert alert-danger border-0 rounded-0">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <div class="text-center mb-4">
                <h1 class="h2 fw-bold" style="font-family: 'Playfair Display', serif;">Veuillez vous connecter</h1>
                <p class="text-muted small">Heureux de vous revoir !</p>
            </div>

            <div class="mb-3">
                <label for="inputEmail" class="form-label small fw-bold text-uppercase text-secondary">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control form-control-lg border-0 bg-light" autocomplete="email" required autofocus placeholder="email@exemple.com">
            </div>

            <div class="mb-3">
                <label for="inputPassword" class="form-label small fw-bold text-uppercase text-secondary">Mot de passe</label>
                <input type="password" name="password" id="inputPassword" class="form-control form-control-lg border-0 bg-light" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="checkbox mb-4 mt-3">
                <label class="small text-muted">
                    <input type="checkbox" name="_remember_me"> Se souvenir de moi
                </label>
            </div>

            {# L-bouton l-animated dhabet kima l-Inscription #}
            <button class="btn btn-animated-light w-100 py-3 fw-bold" type="submit">
                Se connecter <i class="fas fa-sign-in-alt ms-2"></i>
            </button>
            
            <div class="text-center mt-4 pt-2 border-top">
                <p class="small text-muted mb-0">
                    Pas encore de compte ? <a href="{{ path('app_register') }}" class="text-dark fw-bold text-decoration-none">S'inscrire</a>
                </p>
            </div>
        </form>
    </div>
</div>
{% endblock %}
